---
// Golden Waveform design integrated with readable text
---

<div class="waveform-title-container">
  <h1 class="waveform-title">
    <span class="waveform-text-base">Elite Achievers Awards 2026</span>
    <svg class="waveform-overlay" viewBox="0 0 1200 150" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="goldenGradient" x1="0%" y1="0%" x2="0%" y2="100%">
          <stop offset="0%" style="stop-color:#FFD700;stop-opacity:1" />
          <stop offset="50%" style="stop-color:#FFF44F;stop-opacity:1" />
          <stop offset="100%" style="stop-color:#FFD700;stop-opacity:1" />
        </linearGradient>
        
        <filter id="waveGlow">
          <feGaussianBlur stdDeviation="1.5" result="coloredBlur"/>
          <feMerge>
            <feMergeNode in="coloredBlur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>
      </defs>

      <!-- Wave lines flowing across -->
      <g class="wave-lines" filter="url(#waveGlow)">
        <path 
          class="wave-line wave-1"
          d="M 0,60 Q 150,30 300,60 T 600,60 T 900,60 T 1200,60"
          stroke="url(#goldenGradient)"
          stroke-width="3"
          fill="none"
          stroke-linecap="round"
          opacity="0.8"
        />
        
        <path 
          class="wave-line wave-2"
          d="M 0,75 Q 150,50 300,75 T 600,75 T 900,75 T 1200,75"
          stroke="url(#goldenGradient)"
          stroke-width="2.5"
          fill="none"
          stroke-linecap="round"
          opacity="0.6"
        />
        
        <path 
          class="wave-line wave-3"
          d="M 0,90 Q 150,70 300,90 T 600,90 T 900,90 T 1200,90"
          stroke="url(#goldenGradient)"
          stroke-width="2"
          fill="none"
          stroke-linecap="round"
          opacity="0.5"
        />
      </g>
    </svg>
  </h1>
</div>

<style>
  .waveform-title-container {
    width: 100%;
    margin: 1.5rem 0 0.5rem 0;
    display: flex;
    justify-content: center;
  }

  .waveform-title {
    position: relative;
    margin: 0;
    font-family: "Inter", sans-serif;
    font-size: clamp(2.2rem, 5.6vw, 4.6rem);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    width: 100%;
    max-width: 1000px;
  }

  .waveform-text-base {
    display: block;
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, #fff 0%, #f5f5f5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 30px rgba(255, 215, 0, 0.1);
  }

  .waveform-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
    filter: drop-shadow(0 0 15px rgba(255, 215, 0, 0.4));
  }

  .wave-lines {
    display: block;
  }

  .wave-line {
    animation: waveFlow 4s ease-in-out infinite;
  }

  .wave-1 {
    animation-delay: 0s;
  }

  .wave-2 {
    animation-delay: 0.2s;
  }

  .wave-3 {
    animation-delay: 0.4s;
  }

  @keyframes waveFlow {
    0%, 100% {
      transform: translateX(0) translateY(0);
    }
    25% {
      transform: translateX(10px) translateY(-3px);
    }
    50% {
      transform: translateX(0) translateY(0);
    }
    75% {
      transform: translateX(-10px) translateY(3px);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 1024px) {
    .waveform-title {
      font-size: clamp(1.8rem, 4.5vw, 3.5rem);
    }
  }

  @media (max-width: 768px) {
    .waveform-title {
      font-size: clamp(1.5rem, 4vw, 2.5rem);
    }
  }
</style>
