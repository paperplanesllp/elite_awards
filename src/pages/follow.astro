---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <meta name="viewport" content="width=device-width" />
    <title>Follow | Nitely</title>
  </head>
  <body>
    <Navbar />
    <main class="nitely-page" style="padding-top: 7rem;">
      <section class="section follow-section">
        <div class="container nitely-shell">
          <div class="align-centre">
            <h2>Follow @NITELY</h2>

            <div class="grid-4-4">
              <a href="https://instagram.com" class="instagram-link" target="_blank" rel="noreferrer" aria-label="Open Instagram post 1">
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/6578402fe3980522aa46e4e3_pexels-alena-darmel-7715641.webp" loading="lazy" alt="Club scene" class="image-1-1" />
                <div class="instagram-overlay"></div>
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/65782182792a4f62b6995868_Instagram.svg" loading="lazy" alt="Instagram" class="instagram-icon" />
              </a>

              <a href="https://instagram.com" class="instagram-link" target="_blank" rel="noreferrer" aria-label="Open Instagram post 2">
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/6578402ff244b62e54399878_pexels-alena-darmel-7715780.webp" loading="lazy" alt="Club crowd" class="image-1-1" />
                <div class="instagram-overlay"></div>
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/65782182792a4f62b6995868_Instagram.svg" loading="lazy" alt="Instagram" class="instagram-icon" />
              </a>

              <a href="https://instagram.com" class="instagram-link" target="_blank" rel="noreferrer" aria-label="Open Instagram post 3">
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/6578402fff909a617ea6270d_pexels-alena-darmel-7715348.webp" loading="lazy" alt="DJ lights" class="image-1-1" />
                <div class="instagram-overlay"></div>
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/65782182792a4f62b6995868_Instagram.svg" loading="lazy" alt="Instagram" class="instagram-icon" />
              </a>

              <a href="https://instagram.com" class="instagram-link" target="_blank" rel="noreferrer" aria-label="Open Instagram post 4">
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/6578402fcbcdb5fa7119dcc4_pexels-alena-darmel-7715532.webp" loading="lazy" alt="Night stage" class="image-1-1" />
                <div class="instagram-overlay"></div>
                <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/65782182792a4f62b6995868_Instagram.svg" loading="lazy" alt="Instagram" class="instagram-icon" />
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
