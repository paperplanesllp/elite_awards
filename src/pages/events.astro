---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <meta name="viewport" content="width=device-width" />
    <title>Events | Nitely</title>
  </head>
  <body>
    <Navbar />
    <main class="nitely-page" style="padding-top: 7rem;">
      <section class="section no-top-padding events-section">
        <div class="nitely-shell">
          <div class="events-colection-wrap">
            <div class="block-grid" id="upcoming-events">
              <h2 class="block-heading">Upcoming events</h2>
              <a href="/events" class="ghost-button">See all</a>

              <div class="collection-list-wrapper">
                <div class="collection-list">
                  <article class="collection-item">
                    <div class="event-card-wrap">
                      <a href="/events" class="event-link-block" aria-label="Jazz Thursday">
                        <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657842a48c7edcefb026b5f7_pexels-alena-darmel-7715665.jpg" alt="Jazz Thursday" class="image-1-1" loading="lazy" />
                      </a>
                      <div class="date-in-card"><div class="date">Jan</div><div class="date bigger">02</div></div>
                      <div class="event-card-footer">
                        <h3 class="card-heading">Jazz Thursday</h3>
                        <a href="/events" class="button">Tickets</a>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="event-card-wrap">
                      <a href="/events" class="event-link-block" aria-label="Acoustic Tuesday">
                        <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/65784326af1d447a19b1ae5f_pexels-alena-darmel-7715393.jpg" alt="Acoustic Tuesday" class="image-1-1" loading="lazy" />
                      </a>
                      <div class="date-in-card"><div class="date">Jan</div><div class="date bigger">07</div></div>
                      <div class="event-card-footer">
                        <h3 class="card-heading">Acoustic Tuesday</h3>
                        <a href="/events" class="button">Tickets</a>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="event-card-wrap">
                      <a href="/events" class="event-link-block" aria-label="DJ Antony">
                        <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657841e0adf8bcc6d7ea1603_pexels-alena-darmel-7715615.jpg" alt="DJ Antony" class="image-1-1" loading="lazy" />
                      </a>
                      <div class="date-in-card"><div class="date">Dec</div><div class="date bigger">29</div></div>
                      <div class="event-card-footer">
                        <h3 class="card-heading">DJ Antony</h3>
                        <a href="/events" class="button">Tickets</a>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="event-card-wrap">
                      <a href="/events" class="event-link-block" aria-label="Tetra Drum Show">
                        <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/65784261eb77864be56333c6_pexels-alena-darmel-7715853.jpg" alt="Tetra Drum Show" class="image-1-1" loading="lazy" />
                      </a>
                      <div class="date-in-card"><div class="date">Dec</div><div class="date bigger">30</div></div>
                      <div class="event-card-footer">
                        <h3 class="card-heading">Tetra Drum Show</h3>
                        <a href="/events" class="button">Tickets</a>
                      </div>
                    </div>
                  </article>
                </div>
              </div>
            </div>

            <div class="block-grid top-margin">
              <h2 class="block-heading">Past events</h2>
              <a href="/events" class="ghost-button">See all</a>

              <div class="collection-list-wrapper">
                <div class="collection-list">
                  <article class="collection-item">
                    <div class="past-event-card-wrap">
                      <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657bf7fdc257557413ece96c_pexels-monica-silvestre-713149.jpg" alt="Comedy Club Night" class="image-1-1" loading="lazy" />
                      <span class="play-icon" aria-hidden="true"></span>
                      <div class="past-event-card-footer">
                        <h3 class="card-heading">Comedy Club Night</h3>
                        <p>Dec 10, 2023 7:30 PM - 11:30 PM</p>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="past-event-card-wrap">
                      <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657bf588858bb1df6c28292a_pexels-alena-darmel-7715770.jpg" alt="Retro Groove Night" class="image-1-1" loading="lazy" />
                      <span class="play-icon" aria-hidden="true"></span>
                      <div class="past-event-card-footer">
                        <h3 class="card-heading">Retro Groove Night</h3>
                        <p>Nov 15, 2023 9:00 PM - 1:00 AM</p>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="past-event-card-wrap">
                      <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657bf697ab999a174db20fb4_pexels-alena-darmel-7715348.jpg" alt="Latin Fusion Fiesta" class="image-1-1" loading="lazy" />
                      <span class="play-icon" aria-hidden="true"></span>
                      <div class="past-event-card-footer">
                        <h3 class="card-heading">Latin Fusion Fiesta</h3>
                        <p>Oct 5, 2023 8:00 PM - 12:00 AM</p>
                      </div>
                    </div>
                  </article>

                  <article class="collection-item">
                    <div class="past-event-card-wrap">
                      <img src="https://cdn.prod.website-files.com/65783e70779c933cb04336b5/657841ea6039849fb4446962_pexels-alena-darmel-7715625.jpg" alt="Neon Glow Party" class="image-1-1" loading="lazy" />
                      <span class="play-icon" aria-hidden="true"></span>
                      <div class="past-event-card-footer">
                        <h3 class="card-heading">Neon Glow Party</h3>
                        <p>Sep 20, 2023 10:00 PM - 2:00 AM</p>
                      </div>
                    </div>
                  </article>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
