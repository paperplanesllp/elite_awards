---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <meta name="viewport" content="width=device-width" />
    <title>About | Astro Atelier</title>
  </head>
  <body>
    <Navbar />
    <main class="site-shell py-10 sm:py-14">
      <section class="hero-fade rounded-[2rem] border border-[var(--line)] bg-[var(--surface)] p-7 shadow-[0_25px_60px_rgba(23,20,15,0.08)] sm:p-10">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--accent)]">Our Story</p>
        <h1 class="display-font mt-3 max-w-3xl text-4xl font-semibold leading-tight text-[var(--text)] sm:text-5xl">
          We shape digital spaces with editorial clarity and product-level precision.
        </h1>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-[var(--muted)] sm:text-lg">
          Astro Atelier began as a focused craft studio: small team, deep detail, and a belief that modern websites should feel both beautiful and usable from the first scroll.
        </p>
      </section>

      <section class="mt-8 grid gap-4 lg:grid-cols-3">
        <article class="card stagger rounded-3xl p-6">
          <h2 class="display-font text-2xl font-semibold text-[var(--text)]">Human Direction</h2>
          <p class="mt-3 text-sm leading-relaxed text-[var(--muted)]">Every page starts from brand voice and audience intent, not from generic blocks.</p>
        </article>
        <article class="card stagger rounded-3xl p-6">
          <h2 class="display-font text-2xl font-semibold text-[var(--text)]">Clear Systems</h2>
          <p class="mt-3 text-sm leading-relaxed text-[var(--muted)]">Reusable components with consistent spacing, contrast, and responsive behavior.</p>
        </article>
        <article class="card stagger rounded-3xl p-6">
          <h2 class="display-font text-2xl font-semibold text-[var(--text)]">Lasting Quality</h2>
          <p class="mt-3 text-sm leading-relaxed text-[var(--muted)]">Interfaces designed to age well, with maintainable code and practical performance.</p>
        </article>
      </section>

      <section class="mt-8 card rounded-[2rem] p-7 sm:p-9">
        <h2 class="display-font text-3xl font-semibold text-[var(--text)]">How We Work</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-[var(--line)] p-5">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--muted)]">01 Discovery</p>
            <p class="mt-2 text-sm text-[var(--text)]">We align on goals, audience, and measurable outcomes.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] p-5">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--muted)]">02 Design</p>
            <p class="mt-2 text-sm text-[var(--text)]">We establish visual language, content rhythm, and interaction behavior.</p>
          </div>
          <div class="rounded-2xl border border-[var(--line)] p-5">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-[var(--muted)]">03 Launch</p>
            <p class="mt-2 text-sm text-[var(--text)]">We ship polished pages tuned for responsiveness and readability.</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
