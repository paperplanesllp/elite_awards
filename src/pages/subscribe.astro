---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <meta name="viewport" content="width=device-width" />
    <title>Subscribe | Nitely</title>
  </head>
  <body>
    <Navbar />
    <main class="nitely-page" style="padding-top: 7rem;">
      <section class="section subscribe-section">
        <div class="nitely-shell">
          <div class="subscribe-form">
            <form class="subscribe-form-container" action="#" method="post" aria-label="Subscribe Form">
              <h2>Never miss your favorite artist</h2>

              <div class="subscribe-form-grid">
                <label>
                  Name
                  <input class="subscribe-form-input" name="name" type="text" placeholder="Your Name" required />
                </label>

                <label>
                  Email
                  <input class="subscribe-form-input" name="email" type="email" placeholder="Your Email" required />
                </label>

                <label>
                  Phone
                  <input class="subscribe-form-input" name="phone" type="tel" placeholder="Your Phone" />
                </label>

                <label class="full-width">
                  Enquiry
                  <textarea class="subscribe-form-input" name="enquiry" rows="4" placeholder="Tell us what kind of event experience you are looking for"></textarea>
                </label>
              </div>

              <div class="subscribe-actions">
                <input type="submit" class="hero-button subscribe-btn" value="Reserve table" />
                <div class="text-under-field">Get notifications delivered to your email weekly</div>
              </div>
            </form>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
