---
import Navbar from '../components/Navbar.astro';
import EventCalendar from '../components/EventCalendar.astro';
import GoldenWaveform from '../components/GoldenWaveform.astro';
import '../styles/global.css';

const marqueeBlocks = [0, 1, 2, 3];
const marqueeLogos = [0, 1, 2, 3, 4, 5, 6, 7];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/elite_logo.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/elite_logo.png" />
    <link rel="apple-touch-icon" href="/images/elite_logo.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Elite Achievers Awards 2026 - A national celebration recognizing entrepreneurs, leaders, and innovators shaping the future. Join us in April 2026 in Bangalore." />
    <meta name="keywords" content="awards, excellence, entrepreneurs, innovation, recognition, 2026" />
    <meta name="author" content="Elite Achievers Awards" />
    <meta property="og:title" content="Elite Achievers Awards 2026 | Honouring Excellence. Elevating Influence." />
    <meta property="og:description" content="National celebration recognizing entrepreneurs, leaders, and innovators shaping the future." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://eliteachieversawards.com/images/elite_logo.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Elite Achievers Awards 2026" />
    <meta name="twitter:description" content="Honouring Excellence. Elevating Influence." />
    <meta name="twitter:image" content="https://eliteachieversawards.com/images/elite_logo.png" />
    <title>Elite Achievers Awards 2026 | Honouring Excellence. Elevating Influence.</title>
  </head>
  <body>
    <div class="form-loading-overlay" id="form-loading-overlay" aria-hidden="true">
      <div class="form-loading-card" role="status" aria-live="polite" aria-label="Submitting nomination">
        <span class="form-loading-spinner" aria-hidden="true"></span>
        <span class="form-loading-text">Submitting nomination...</span>
      </div>
    </div>

    <Navbar />
    <EventCalendar />
    <main class="nitely-page">
      <section class="section homepage-hero">
        <div class="background-video" aria-hidden="true">
          <video
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
          >
            <source src="/videos/herov1.mp4" type="video/mp4" />
          </video>
        </div>
        <div class="hero-overlay"></div>

        <div class="nitely-shell hero-content-wrap">
          <div class="hero-stage">
            <div class="hero-copy">
              <img src="/images/paperplanes logo.png" alt="PaperPlanes Logo" style="width: 320px; max-width: 72vw; height: auto;" />
              <GoldenWaveform />
              <p class="hero-tagline">Honouring Excellence. Elevating Influence.</p>
              <p class="hero-support">A national celebration recognizing entrepreneurs, leaders, and innovators shaping the future.</p>

              <div class="hero-foot" aria-label="Event details">
                <a href="/" class="hero-apply-btn" data-scroll-target="upcoming-events">Explore The Event</a>
                <div class="hero-facts">
                  <div class="hero-fact-item">
                    <span class="hero-fact-label">Date</span>
                    <span class="hero-fact-value">25<sup>th</sup>July </span>
                  </div>
                  <div class="hero-fact-item">
                    <span class="hero-fact-label">Location</span>
                    <span class="hero-fact-value">Bangalore</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <a href="/" class="scroll-down-lottie" data-scroll-target="upcoming-events" aria-label="Scroll to upcoming events">
          <span class="scroll-pill"></span>
        </a>
      </section>

      <section class="section no-top-padding events-section">
        <div class="nitely-shell">
          <div class="events-colection-wrap">
            <div class="block-grid packages-block reveal-up" id="upcoming-events">
              <div class="package-reference-head">
                <h2 class="block-heading">Payment Packages</h2>
              </div>

              <div class="package-cards-section package-cards-inline" aria-label="Payment packages">
                <div class="package-grid">
                  <article class="package-card package-card-premium">
                    <span class="package-plan-badge">Most Popular</span>
                    <p class="package-tier">Platinum</p>
                    <p class="package-price"><span class="package-price-label">From</span>INR 79,900</p>
                    <div class="package-divider"></div>
                    <ul class="package-features">
                      <li>Award presentation by Chief Guest (on stage)</li>
                      <li>Exclusive networking opportunities</li>
                      <li>Complimentary hospitality (lunch, tea, and snacks)</li>
                      <li>Wall of Fame recognition</li>
                      <li>1-page magazine feature</li>
                      <li>Personal branding on website</li>
                      <li>1 accompany pass</li>
                      <li>Name display at event</li>
                      <li>Premium media coverage (individual photo and video + edited visuals)</li>
                      <li>Online media publication across 75+ portals</li>
                    </ul>
                    <div class="package-divider"></div>
                    <a href="#contact-section" class="hero-button package-card-cta">Choose Plan</a>
                  </article>

                  <article class="package-card package-card-gold">
                    <p class="package-tier">Gold</p>
                    <p class="package-price"><span class="package-price-label">From</span>INR 59,900</p>
                    <div class="package-divider"></div>
                    <ul class="package-features">
                      <li>Award presentation by Chief Guest (on stage)</li>
                      <li>Trophy and certificate on stage</li>
                      <li>Exclusive networking opportunities</li>
                      <li>Complimentary hospitality (lunch, tea, and snacks)</li>
                      <li>Wall of Fame recognition</li>
                      <li>1-page magazine feature</li>
                      <li>Personal branding on website</li>
                      <li>1 accompany pass</li>
                      <li>Name display at event</li>
                      <li>Online media publication across 75+ portals</li>
                    </ul>
                    <div class="package-divider"></div>
                    <a href="#contact-section" class="hero-button package-card-cta">Choose Plan</a>
                  </article>

                  <article class="package-card package-card-silver">
                    <p class="package-tier">Silver</p>
                    <p class="package-price"><span class="package-price-label">From</span>INR 36,900</p>
                    <div class="package-divider"></div>
                    <ul class="package-features">
                      <li>Award presentation by Chief Guest (on stage)</li>
                      <li>Trophy and certificate on stage</li>
                      <li>Exclusive networking opportunities</li>
                      <li>Complimentary hospitality (lunch, tea, and snacks)</li>
                      <li>1 accompany pass</li>
                      <li>Name display at event</li>
                    </ul>
                    <div class="package-divider"></div>
                    <a href="#contact-section" class="hero-button package-card-cta">Choose Plan</a>
                  </article>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <div class="infinite-marquee-wrap">
        {marqueeBlocks.map((block) => (
          <div class="infinite-marquee-block" aria-hidden="true">
            {marqueeLogos.map((logo) => (
              <>
                <span class="marquee-icon">✦</span>
                <span class="marquee-text">25-07-2026</span>
                <div class="marquee-separator"></div>
              </>
            ))}
          </div>
        ))}
      </div>

      <section class="section exclusive-section" id="about-section">
        <div class="nitely-shell">
          <div class="grid-2-2">
            <img
              src="/images/about.jpeg"
              loading="lazy"
              alt="Nightclub interior"
              class="image-3-2"
            />

            <div class="exclusive-copy align-left reveal-side-right">
              <p class="exclusive-eyebrow">Paperplanes Excellence</p>
              <h2 class="hero-heading">What Sets Paperplanes Apart</h2>
              <p class="subheading">
                Prestigious business events and award platforms across diverse industries.
              </p>
              <ul class="exclusive-points" aria-label="Paperplanes strengths">
                <li class="exclusive-point">Proven excellence in event execution, brand positioning, and high-value networking.</li>
                <li class="exclusive-point">A rapidly growing and trusted name in event management, PR, and celebrity collaborations.</li>
                <li class="exclusive-point">End-to-end solutions covering events, media, influencer marketing, branding, and promotions.</li>
                <li class="exclusive-point">Strong industry connections enabling impactful collaborations with brands, creators, and leaders.</li>
                <li class="exclusive-point">Expertise in creating premium, experience-driven events that leave a lasting impression.</li>
              </ul>
              <p class="subheading">
                Paperplanes' flagship initiatives are designed to go beyond traditional events, crafting powerful platforms where talent is celebrated, brands gain visibility, and meaningful connections are built. With a focus on innovation and quality, Paperplanes continues to shape experiences that elevate recognition into legacy and transform ideas into impactful success stories.
              </p>
              <a href="/" data-scroll-target="contact-section" class="hero-button">Nominate Now</a>
            </div>
          </div>
        </div>
      </section>

      <div class="infinite-marquee-wrap secondary-color">
        {marqueeBlocks.map((block) => (
          <div class="infinite-marquee-block" aria-hidden="true">
            {marqueeLogos.map((logo) => (
              <>
                <span class="marquee-icon">◆</span>
                <span class="marquee-text secondary">25-07-2026</span>
                <div class="marquee-separator accent"></div>
              </>
            ))}
          </div>
        ))}
      </div>

      <section class="section subscribe-section" id="contact-section">
        <div class="nitely-shell">
          <div class="subscribe-form reveal-up">
            <form class="subscribe-form-container" id="enquiry-form" action="#" method="post" aria-label="Nomination Form">
              <h2>Fill Up This Nomination Form</h2>

              <div class="subscribe-form-grid">
                <label>
                  Title
                  <select class="subscribe-form-input" name="title" required>
                    <option value="" selected>-Select-</option>
                    <option value="Mr">Mr</option>
                    <option value="Ms">Ms</option>
                    <option value="Mrs">Mrs</option>
                    <option value="Dr">Dr</option>
                    <option value="Prof">Prof</option>
                  </select>
                </label>

                <label>
                  Your Full Name
                  <input class="subscribe-form-input" name="name" type="text" placeholder="Name" required />
                </label>

                <label>
                  Organisation name
                  <input class="subscribe-form-input" name="organisation" type="text" placeholder="Organisation name" required />
                </label>

                <label>
                  Phone Number
                  <input class="subscribe-form-input" name="phone" type="tel" placeholder="Phone Number" required />
                </label>

                <label>
                  Email Address
                  <input class="subscribe-form-input" name="email" type="email" placeholder="Email Address" required />
                </label>

                <label class="full-width">
                  Address of Correspondence
                  <textarea class="subscribe-form-input" name="address" rows="3" placeholder="Address of Correspondence" required></textarea>
                </label>

                <label>
                  GSTIN (Optional)
                  <input class="subscribe-form-input" name="gstin" type="text" placeholder="GSTIN" />
                </label>


                <label>
                  What best describes you?
                  <select class="subscribe-form-input" name="profileType" id="profile-type-select" required>
                    <option value="" selected>-Select-</option>
                    <option value="Entrepreneurs/Business">Entrepreneurs / Business</option>
                    <option value="Startups">Startups</option>
                    <option value="Manufacturing">Manufacturing</option>
                    <option value="Business Services">Business Services</option>
                    <option value="Companies">Companies</option>
                    <option value="Health & Wellness Coach">Health & Wellness Coach</option>
                    <option value="Human Resource">Human Resource</option>
                    <option value="NGOs">NGOs</option>
                    <option value="Healthcare">Healthcare</option>
                    <option value="Product/Business & Idea">Product / Business & Idea</option>
                    <option value="Beauty & Wellness">Beauty & Wellness</option>
                    <option value="Blogs">Blogs</option>
                    <option value="Apps">Apps</option>
                    <option value="Artists & Authors">Artists & Authors</option>
                    <option value="YouTubers">YouTubers</option>
                    <option value="Social Media & Influencers">Social Media & Influencers</option>
                    <option value="Technology">Technology</option>
                    <option value="Retail & Ecommerce">Retail & Ecommerce</option>
                    <option value="Food & Beverages">Food & Beverages</option>
                    <option value="Tourism & Hospitality">Tourism & Hospitality</option>
                    <option value="Real Estate">Real Estate</option>
                    <option value="Entertainment">Entertainment</option>
                    <option value="Practitioners & Professionals">Practitioners & Professionals</option>
                    <option value="Researchers">Researchers</option>
                    <option value="Influencers">Influencers</option>
                    <option value="Photographer/Videographer">Photographer / Videographer</option>
                    <option value="Journalist">Journalist</option>
                    <option value="Architect">Architect</option>
                    <option value="Sports">Sports</option>
                    <option value="Fashion Designer">Fashion Designer</option>
                    <option value="Interior Designer">Interior Designer</option>
                    <option value="Astrologers/Tarot Reader">Astrologers / Tarot Reader</option>
                    <option value="Advocate">Advocate</option>
                    <option value="Chef">Chef</option>
                    <option value="Restaurant">Restaurant</option>
                    <option value="Gym Trainer">Gym Trainer</option>
                    <option value="Principal/Vice Principal">Principal / Vice Principal</option>
                    <option value="Academics Director">Academics Director</option>
                    <option value="Teacher/Trainer">Teacher / Trainer</option>
                    <option value="Professor">Professor</option>
                    <option value="School">School</option>
                    <option value="Higher Education">Higher Education</option>
                    <option value="Coaching Institute">Coaching Institute</option>
                    <option value="Service Provider">Service Provider</option>
                    <option value="Other">Other</option>

                  </select>
                </label>


                <label>
                  Select your Sector
                  <select class="subscribe-form-input" name="sector" id="sector-select" required disabled>
                    <option value="" selected>-Select-</option>
                  </select>
                </label>

                <label>
                  Award Categories
                  <select class="subscribe-form-input" name="awardCategory" id="award-category-select" required disabled>
                    <option value="" selected>Select Award Categories</option>
                  </select>
                </label>

                <label>
                  Website
                  <input class="subscribe-form-input" name="website" type="url" placeholder="Website" />
                </label>

                <label>
                  Are you Interested to apply for an Honorary Doctorate?
                  <select class="subscribe-form-input" name="doctorateInterest" required>
                    <option value="" selected>-Select-</option>
                    <option value="Yes">Yes</option>
                    <option value="No">No</option>
                  </select>
                </label>

                <label class="full-width nomination-terms">
                  <span class="nomination-terms-row">
                    <input type="checkbox" id="termsAccepted" name="termsAccepted" required />
                    <span class="nomination-terms-content">
                      <span class="nomination-terms-title">I agree to the Terms and Conditions</span>
                      <span class="nomination-terms-note"><strong>Nomination fee:</strong> INR 1990/- only.</span>
                      <span class="nomination-terms-note">Only selected awardees will get a chance to attend the conference.</span>
                      <span class="nomination-terms-note">For non-selected nominees, the fee will be refunded.</span>
                      <span class="nomination-terms-note">For selected awardees, a conference fee is also included.</span>
                    </span>
                  </span>
                </label>
              </div>

              <div class="subscribe-actions">
                <input type="submit" class="hero-button subscribe-btn" value="Submit Nomination" />
                <div class="text-under-field" id="enquiry-status">Complete the form to submit your nomination.</div>
              </div>
            </form>

          </div>
        </div>
      </section>

      <section class="section footer" id="footer-section">
        <div class="nitely-shell">
          <div class="footer-wrapper reveal-up">
            <div class="footer-column footer-brand-col">
              <a href="/" class="footer-brand" aria-label="Elite Achievers Awards Home">
                <img src="../images/elite_logo.png" loading="lazy" alt="Elite Achievers Awards" class="logo" width="50 " height="50" />
                <p class="copy-under-logo">National celebration recognizing excellence & innovation.</p>
              </a>

              <div class="follow-us-wrap">
                <div class="footer-title">Follow @ELITEACHIEVERSAWARDS</div>
                <div class="social-links-wrap">
                  <a href="https://www.instagram.com/eliteachieversawards?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" class="social-icon-link" target="_blank" rel="noreferrer" aria-label="Instagram">
                    <img src="https://cdn.prod.website-files.com/65782009fd8595214ed53f48/65782182792a4f62b6995868_Instagram.svg" loading="lazy" alt="Instagram" class="social-icon-image" />
                  </a>
                </div>
              </div>
            </div>

            <div class="footer-column">
              <div class="footer-title">Navigation</div>
              <a href="/" data-scroll-target="upcoming-events" class="link-footer">Events</a>
              <a href="/" data-scroll-target="about-section" class="link-footer">About</a>
              <a href="/" data-scroll-target="contact-section" class="link-footer">Nomination Form</a>
              <button class="link-footer" onclick="window.openEventCalendar()" >Events Calendar</button>
            </div>

            <div class="footer-column">
              <div class="footer-title">PR Department</div>
              <a href="tel:+919037915305" class="link-footer">+91 90379 15305</a>
              <a href="tel:+919995772002" class="link-footer">+91 99957 72002</a>
            </div>

            <div class="footer-column">
              <div class="footer-title">Sales Department</div>
              <a href="tel:+919037915305" class="link-footer">+91 90379 15305</a>
              <a href="tel:+919995772002" class="link-footer">+91 99957 72002</a>
            </div>
          </div>

          <div class="footer-bottom">
            <div class="footer-divider"></div>
            <div class="footer-bottom-content">
              <p>&copy; 2026 Elite Achievers Awards. All rights reserved.</p>
              <a href="https://eliteachieversawards.com" target="_blank" rel="noreferrer" class="footer-website-link">eliteachieversawards.com</a>
            </div>
          </div>
        </div>
      </section>

      <script>
        const observer = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in-view');
                obs.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.05,
            rootMargin: '0px 0px -8% 0px',
          }
        );

        document.querySelectorAll('.reveal-up, .reveal-side-left, .reveal-side-right').forEach((node) => {
          observer.observe(node);
        });

        const enquiryForm = document.querySelector('#enquiry-form') as HTMLFormElement | null;
        const enquiryStatus = document.querySelector('#enquiry-status') as HTMLElement | null;
        const formLoadingOverlay = document.querySelector('#form-loading-overlay') as HTMLElement | null;
        const profileTypeSelect = document.querySelector('#profile-type-select') as HTMLSelectElement | null;
        const sectorSelect = document.querySelector('#sector-select') as HTMLSelectElement | null;
        const awardCategorySelect = document.querySelector('#award-category-select') as HTMLSelectElement | null;

        const setFormLoading = (isLoading: boolean) => {
          if (!formLoadingOverlay) return;

          formLoadingOverlay.classList.toggle('is-visible', isLoading);
          formLoadingOverlay.setAttribute('aria-hidden', isLoading ? 'false' : 'true');
          document.body.classList.toggle('is-loading-form', isLoading);
        };

