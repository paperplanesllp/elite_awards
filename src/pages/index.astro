        const setSectorOptions = (profileType: string) => {
          if (!sectorSelect) return;

          sectorSelect.innerHTML = '';

          const placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = '-Select-';
          placeholder.selected = true;
          sectorSelect.appendChild(placeholder);

          const matchedSectors = sectorsByProfileType[profileType];
          const sectors = matchedSectors || [];
          sectors.forEach((sector) => {
            const option = document.createElement('option');
            option.value = sector;
            option.textContent = sector;
            sectorSelect.appendChild(option);
          });

          sectorSelect.disabled = sectors.length === 0;
        };

        const setAwardCategoryOptions = (sector: string) => {
          if (!awardCategorySelect) return;

          awardCategorySelect.innerHTML = '';

          const placeholder = document.createElement('option');
          placeholder.value = '';
          placeholder.textContent = 'Select Award Categories';
          placeholder.selected = true;
          awardCategorySelect.appendChild(placeholder);

          const categories = awardCategoriesBySector[sector] || [];
          categories.forEach((category) => {
            const option = document.createElement('option');
            option.value = category;
            option.textContent = category;
            awardCategorySelect.appendChild(option);
          });

          awardCategorySelect.disabled = categories.length === 0;
        };

        if (profileTypeSelect && sectorSelect && awardCategorySelect) {
          setSectorOptions(profileTypeSelect.value);
          setAwardCategoryOptions(sectorSelect.value);

          profileTypeSelect.addEventListener('change', (event) => {
            const selectedProfileType = (event.target as HTMLSelectElement).value;
            setSectorOptions(selectedProfileType);
            setAwardCategoryOptions('');
          });

          sectorSelect.addEventListener('change', (event) => {
            const selectedSector = (event.target as HTMLSelectElement).value;
            setAwardCategoryOptions(selectedSector);
          });
        }

        if (enquiryForm && enquiryStatus) {
          enquiryForm.addEventListener('submit', async (event) => {
            event.preventDefault();

            const submitButton = enquiryForm.querySelector('input[type="submit"]') as HTMLInputElement | null;
            if (submitButton) submitButton.disabled = true;
            setFormLoading(true);

            enquiryStatus.textContent = 'Submitting your nomination...';
            enquiryStatus.classList.remove('success', 'error');
            enquiryStatus.classList.add('submitting');

            const formData = new FormData(enquiryForm);
            const getSelectLabel = (name: string) => {
              const field = enquiryForm.elements.namedItem(name);
              if (field instanceof HTMLSelectElement) {
                const selected = field.options[field.selectedIndex];
                return selected?.text?.trim() || String(formData.get(name) || '');
              }
              return String(formData.get(name) || '');
            };

            const titleLabel = getSelectLabel('title');
            const profileTypeLabel = getSelectLabel('profileType');
            const sectorLabel = getSelectLabel('sector');
            const awardCategoryLabel = getSelectLabel('awardCategory');
            const doctorateInterestLabel = getSelectLabel('doctorateInterest');

            const nominationSummary = [
              `Title: ${titleLabel}`,
              `Profile Type: ${profileTypeLabel}`,
              `Organisation: ${String(formData.get('organisation') || '')}`,
              `Address: ${String(formData.get('address') || '')}`,
              `GSTIN: ${String(formData.get('gstin') || 'Not provided')}`,
              `Sector: ${sectorLabel}`,
              `Award Category: ${awardCategoryLabel}`,
              `Website: ${String(formData.get('website') || 'Not provided')}`,
              `Honorary Doctorate Interest: ${doctorateInterestLabel}`,
              `Terms Accepted: ${formData.get('termsAccepted') ? 'Yes' : 'No'}`,
            ].join('\n');

            const payload = {
              name: String(formData.get('name') || ''),
              email: String(formData.get('email') || ''),
              phone: String(formData.get('phone') || ''),
              title: titleLabel,
              profileType: profileTypeLabel,
              organisation: String(formData.get('organisation') || ''),
              address: String(formData.get('address') || ''),
              gstin: String(formData.get('gstin') || 'Not provided'),
              sector: sectorLabel,
              awardCategory: awardCategoryLabel,
              website: String(formData.get('website') || 'Not provided'),
              doctorateInterest: doctorateInterestLabel,
              termsAccepted: formData.get('termsAccepted') ? 'Yes' : 'No',
              enquiry: nominationSummary,
              from_name: String(formData.get('name') || ''),
              from_email: String(formData.get('email') || ''),
              from_phone: String(formData.get('phone') || ''),
              reply_to: String(formData.get('email') || ''),
              message: nominationSummary,
              subject: 'New nomination form submission',
            };

            try {
              const response = await fetch('/api/enquiry', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                },
                body: JSON.stringify(payload),
              });

              const result = await response.json();
              if (!response.ok) {
                throw new Error(result.message || 'Unable to submit nomination right now.');
              }

              enquiryStatus.textContent = 'Thank you. Your nomination has been received successfully.';
              enquiryStatus.classList.remove('submitting', 'error');
              enquiryStatus.classList.add('success');
              enquiryForm.reset();
              setSectorOptions('');
              setAwardCategoryOptions('');
            } catch (error) {
              const message = error instanceof Error ? error.message : 'Unable to submit nomination right now.';
              enquiryStatus.textContent = message;
              enquiryStatus.classList.remove('submitting', 'success');
              enquiryStatus.classList.add('error');
            } finally {
              setFormLoading(false);
              if (submitButton) submitButton.disabled = false;
            }
          });
        }
      </script>
    </main>
  </body>
</html>
